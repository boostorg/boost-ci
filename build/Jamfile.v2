import configure ;

project
  : source-location ../src
  : common-requirements <library>$(boost_dependencies)
 ;

lib boost_boost_ci
  : boost_ci.cpp
  : requirements  <link>shared:<define>BOOST_BOOST_CI_DYN_LINK=1
  ;